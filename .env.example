# --- Database ---
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://dheli:change-me@db:5432/dheli

# --- App secrets (generate with: openssl rand -hex 32) ---
SESSION_SECRET=replace-with-32-char-hex
ADMIN_SECRET=replace-with-hex

# --- Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Realtime (SECRET_KEY_BASE must be 64+ chars) ---
REALTIME_SECRET_KEY_BASE=replace-with-64-char-hex
REALTIME_JWT_SECRET=replace-with-hex

# --- Supabase client config (leave blank until you point at a Realtime instance) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Scraper ---
APP_INTERNAL_URL=http://app:3000
