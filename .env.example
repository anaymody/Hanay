# --- Supabase Database (Settings > Database > Connection string > URI) ---
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# --- App secrets (generate with: openssl rand -hex 32) ---
SESSION_SECRET=replace-with-32-char-hex
ADMIN_SECRET=replace-with-hex

# --- Gemini (https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=

# --- Supabase client config (Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Scraper ---
APP_INTERNAL_URL=http://app:3000
